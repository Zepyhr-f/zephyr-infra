# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=appdb

# Timezone
TZ=Asia/Shanghai

# Data directory
DATA_DIR=./data

# Nginx
NGINX_HTTP_PORT=80

# Redis
REDIS_PASSWORD=redis

# NATS
NATS_CLIENT_PORT=4222
NATS_MONITOR_PORT=8222

# Consul
CONSUL_HTTP_PORT=8500
CONSUL_DNS_PORT=8600
